# Example environment settings for Zepto AI Discovery Engine
DATA_DIR=data
RAW_DATA_DIR=data/raw
PROCESSED_DATA_DIR=data/processed
SOURCE_PLAY_STORE_URL=https://play.google.com/store/apps/details?id=com.zeptoconsumerapp&hl=en_IN
SOURCE_APP_STORE_URL=https://apps.apple.com/in/app/zepto-groceries-in-minutes/id1575323645?see-all=reviews&platform=iphone
SOURCE_REDDIT_URL=https://www.reddit.com/search/?q=Reviews+of+Zepto+Service+in+india&cId=f4c2ed62-4010-40b0-9738-cc673e019b94&iId=52089c62-0722-4478-9394-f24d1ed62e95
# Groq API configuration (set these to use Groq as the LLM/embedding provider)
# Example: GROQ_API_KEY=your_groq_api_key
GROQ_API_KEY=
# Optional: base URL for Groq API. Default points to Groq's public API endpoint.
GROQ_BASE_URL=https://api.groq.ai
# Model names for small and large embedding models
GROQ_SMALL_MODEL=bge-small
GROQ_LARGE_MODEL=bge-large
